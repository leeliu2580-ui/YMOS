# YMOS V3 环境变量配置
# 复制本文件为 .env，填入你的 Key 即可。
# 所有 Key 均为可选 —— 不配置则自动降级到免费数据源（RSS + Yahoo Finance）。
# 详见 进阶指南.md 的数据层级说明。

# ── Level 1：Finnhub Free API（推荐，免费注册） ──
# 注册地址：https://finnhub.io
# 解锁能力：美股/Crypto 实时报价 + 持仓个股英文新闻
# 对应脚本：Eyes/scripts/fetch_price_api.py, Eyes/scripts/fetch_finnhub_news.py
# 无此 Key 时：价格走 Yahoo Finance 兜底，无个股新闻
FINNHUB_API_KEY=

# ── Level 1+：Tushare Pro Token（A股用户推荐，免费注册） ──
# 注册地址：https://tushare.pro
# 解锁能力：A股（.SS/.SZ）日线价格，比 Yahoo Finance 更稳定
# 对应脚本：Eyes/scripts/fetch_price_tushare.py
# Ticker 格式：状态机写 .SS/.SZ，脚本内部自动将 .SS → .SH 转换
# 无此 Token 时：A股价格走 Yahoo Finance 兜底
TUSHARE_TOKEN=

# ── Level 2：Market Data API（进阶，需联系获取） ──
# 说明：结构化中英文市场事件数据源，28 源预处理
# 对应脚本：Eyes/scripts/fetch_market_api.py
# 无此 Key 时：市场洞察仅使用 RSS 源（完全可用）
YMOS_MARKET_API_URL=https://yongmai.xyz/wp-json/tib/v1/reports
YMOS_MARKET_API_KEY=
